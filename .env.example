# ---------------------------------------------------------------------------
# Shopify Storefront API
# Copy this file to `.env.local` and fill in real values (never commit .env.local).
# ---------------------------------------------------------------------------

# Your store domain, e.g. your-store.myshopify.com  (no protocol, no trailing slash)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=

# Public Storefront API access token.
# This token is DESIGNED to be public (client-readable). It only grants the
# Storefront API scopes you enable in the Shopify admin. NEVER put the Admin
# API token here.
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Storefront API version (YYYY-MM). Pin this and bump deliberately.
NEXT_PUBLIC_SHOPIFY_API_VERSION=2025-01

# Public site URL, used for canonical URLs, sitemap, and OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
